---
import logoUrl from '../assets/logo-mark.svg?url';
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
	<img src={logoUrl} alt="" aria-hidden="true" class="logo-mark" />
	<span translate="no" class="title-text">
		Open Aviation <span class="accent">Solutions</span>
	</span>
</a>

<style>
	@layer starlight.core {
		.site-title {
			align-items: center;
			gap: var(--sl-nav-gap);
			font-size: var(--sl-text-h4);
			font-weight: 600;
			text-decoration: none;
			white-space: nowrap;
			min-width: 0;
		}
		.logo-mark {
			height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
			width: auto;
			max-width: 100%;
			object-fit: contain;
			object-position: 0 50%;
		}
		.title-text {
			color: var(--sl-color-white);
			overflow: hidden;
		}
		.accent {
			color: var(--sl-color-accent-high);
		}
	}
</style>
